	)
	(text "6.1V @ ~700ma max\n(~350ma per cassette port)\n\nVoltage and limits derived from\nPET schematics and datasheets\n\nVoltage is non-critical as the\ndatasette speed is controlled by\na mechanical governor.\n\nHeatsink does not appear to be\nrequired for a single Datasette.\n\n(Running two Datasettes at the\nsame time hasn't been tested.)\n"
		(exclude_from_sim no)
		(at 232.41 82.55 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "d3af371b-eb23-4d75-8c1b-61cf84e3f244")
	)
	(text "AMS1117 datasheet specifies 22u tant,\nbut does not state a required ESR\nrange for stability.\n\nTI LM1117 specifies 0.3-22Ω. Each C_{OUT}\nis 3Ω @ 100kHz (for 1.5Ω in parallel).\n\nAMS1117 internal protection diodes\nsufficient with output caps < 1000uF"
		(exclude_from_sim no)
		(at 118.11 193.04 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "e2f3c9c0-778d-439c-b715-986d67505161")
	)
