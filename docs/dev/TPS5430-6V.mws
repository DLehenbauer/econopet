requency\nF_SW_kHz := 500;\nF_SW := F_SW_kHz * 1000;\n\n# TI recommend
s 0.2-0.3.  Uses 0.2 in reference design.\nK_IND := 0.2;\n\n# Is this \+
the maximum ripple voltage?\nV_OUT_MAX := 6.5;\n\nL_MIN := (V_OUT_MAX \+
* (V_IN_MAX - V_OUT)) / (V_IN_MAX * K_IND * I_OUT * F_SW);\nL_MIN_uH :
= L_MIN * 10^6;\nevalf(%);\n\n# Choose next available size larger:\nL_
O_uH := 22;\nL_O := L_O_uH * 10^(-6);\n\n" }}{PARA 11 "" 1 "" 
